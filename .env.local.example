# SynapseCRO environment variables
# Copy to .env.local and fill in values: cp .env.local.example .env.local

# ── Supabase (required) ──────────────────────────────────────────────────────
# Project URL — use either naming convention
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_URL=https://your-project.supabase.co

# Anon / publishable key (client-safe; used in browser + middleware session)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Service role / secret key (server-side only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_SECRET_KEY=your-service-role-key

# ── LLM (required for full agent; offline heuristics work without this) ─────
# Anthropic API key — powers /api/optimize, research agent, messaging synthesis, GitHub PR edits
# Gemini (DeepMind) — primary LLM for research agent, CRO optimize, GitHub PR edits
# Primary name (@ai-sdk/google convention); GEMINI_API_KEY is an alias (checked first):
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# GEMINI_API_KEY=your-gemini-api-key
# All-time Gemini spend cap in USD (default: 30)
GEMINI_SPEND_CAP_USD=30
# Optional global cap across all tracked APIs (Gemini, Tavily, Firecrawl, Resend, etc.)
# GLOBAL_SPEND_CAP_USD=50
# Optional per-provider caps (unset = unlimited)
# TAVILY_SPEND_CAP_USD=10
# FIRECRAWL_SPEND_CAP_USD=5
# RESEND_SPEND_CAP_USD=5
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic — fallback LLM if GEMINI_API_KEY is not set
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ── Optional: enhanced SERP & scraping ───────────────────────────────────────
# Tavily — AI web search for lead discovery, competitor research, social profile search
TAVILY_API_KEY=your-tavily-key

# Firecrawl — JS-rendered page scraping in research audits (cheerio fetch is the fallback)
FIRECRAWL_API_KEY=your-firecrawl-key

# ── Optional: GitHub PR automation ───────────────────────────────────────────
# Option A — GitHub App (recommended for production; per-user install tokens)
# Register manually: docs/GITHUB_APP_SETUP.md
# GITHUB_APP_ID=123456
# GITHUB_APP_SLUG=synapsecro
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_WEBHOOK_SECRET=your-webhook-secret

# Option B — shared Personal Access Token (local dev / single-tenant fallback)
GITHUB_TOKEN=ghp_your-github-personal-access-token
# This app's own repo ("owner/name") — target for prompt self-improvement PRs (/api/prompts/improve)
# APP_GITHUB_REPO=ramstar3000/seo_tool

# ── Optional: cron bypass for /api/optimize ──────────────────────────────────
# Manual triggers: Authorization: Bearer $CRON_SECRET
# Vercel production cron uses the x-vercel-cron header automatically
CRON_SECRET=your-random-cron-secret

# ── Optional: Core Web Vitals (PageSpeed Insights) ───────────────────────────
GOOGLE_PAGESPEED_API_KEY=your-google-api-key
# Falls back to GOOGLE_API_KEY if unset (PageSpeed only — not used for Gemini/LLM)
# GOOGLE_API_KEY=your-google-api-key

# ── Optional: Slack notifications ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Optional: local database reset (scripts/reset-and-seed.sh) ────────────────
# Direct Postgres URI from Supabase Dashboard → Project Settings → Database → Connection string
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...

# ── Optional: email notifications ────────────────────────────────────────────
# Resend — sends actionable audit summary when visitor audits complete (gracefully skipped if unset)
RESEND_API_KEY=re_your-resend-api-key
# For testing, onboarding@resend.dev only delivers to your Resend account email.
# For production, verify a domain at resend.com/domains and use:
# RESEND_FROM_EMAIL=SynapseCRO <hello@yourdomain.com>
# Where prospect replies land (Reply-To). Send from the cold-send domain, read replies here.
# Defaults to ram+seo@acyclic.dev if unset.
# RESEND_REPLY_TO_EMAIL=ram+seo@acyclic.dev

# Outreach — leads have no prospect email in the DB; drafts go here until you add emails manually.
# With onboarding@resend.dev, this must be the email on your Resend account.
# OUTREACH_TARGET_EMAIL=you@example.com

# ── Optional: app URL for emails and links ─────────────────────────────────────
# Fly sets FLY_APP_NAME automatically; override with a custom domain if needed:
# NEXT_PUBLIC_APP_URL=https://synapsecro.fly.dev

# ── Fly.io cron (replaces Vercel x-vercel-cron header) ───────────────────────
# CRON_SECRET=your-random-cron-secret

# ── Optional: ClickHouse analytics (hackathon / production) ─────────────────
# Local ClickHouse (docker compose -f docker-compose.clickhouse.yml up -d)
# CLICKHOUSE_URL=http://localhost:8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default

# ClickHouse Cloud free tier — sensory stream (conversion funnel) + cognitive memory (SEO insights)
# Get these from: Services → your service → Connect → Node.js (NOT Settings → API Keys)
# CLICKHOUSE_URL=https://YOUR_HOST.clickhouse.cloud:8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=your-database-password-from-connect-tab
# CLICKHOUSE_DATABASE=default

# Cloud console API keys (Settings → API Keys) — for clickhousectl / management only, NOT used by this app:
# CLICKHOUSE_KEY_ID=...
# CLICKHOUSE_API_KEY=...

# Langfuse (ClickHouse-acquired LLM observability + evals) — traces every optimize + audit ingest
# Create project at https://cloud.langfuse.com → Settings → API Keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Reserved (not wired yet) ─────────────────────────────────────────────────
# GOOGLE_PLACES_API_KEY=your-google-places-key
