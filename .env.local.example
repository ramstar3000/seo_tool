# SynapseCRO environment variables
# Copy to .env.local and fill in values: cp .env.local.example .env.local

# ── Supabase (required) ──────────────────────────────────────────────────────
# Project URL — use either naming convention
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_URL=https://your-project.supabase.co

# Anon / publishable key (client-safe; used in browser + middleware session)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Service role / secret key (server-side only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_SECRET_KEY=your-service-role-key

# ── LLM (required for full agent; offline heuristics work without this) ─────
# Anthropic API key — powers /api/optimize, research agent, messaging synthesis, GitHub PR edits
# Gemini (DeepMind) — primary LLM for research agent, CRO optimize, GitHub PR edits
GEMINI_API_KEY=your-gemini-api-key
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic — fallback LLM if GEMINI_API_KEY is not set
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ── Optional: enhanced SERP & scraping ───────────────────────────────────────
# Tavily — AI web search for lead discovery, competitor research, social profile search
TAVILY_API_KEY=your-tavily-key

# Firecrawl — JS-rendered page scraping in research audits (cheerio fetch is the fallback)
FIRECRAWL_API_KEY=your-firecrawl-key

# ── Optional: GitHub PR automation ───────────────────────────────────────────
# Personal access token with repo scope — creates branches/PRs from audit findings
GITHUB_TOKEN=ghp_your-github-personal-access-token

# ── Optional: cron bypass for /api/optimize ──────────────────────────────────
# Manual triggers: Authorization: Bearer $CRON_SECRET
# Vercel production cron uses the x-vercel-cron header automatically
CRON_SECRET=your-random-cron-secret

# ── Optional: Core Web Vitals (PageSpeed Insights) ───────────────────────────
GOOGLE_PAGESPEED_API_KEY=your-google-api-key

# ── Optional: Slack notifications ──────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ── Optional: local database reset (scripts/reset-and-seed.sh) ────────────────
# Direct Postgres URI from Supabase Dashboard → Project Settings → Database → Connection string
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres.[ref]:[password]@...

# ── Optional: email notifications ────────────────────────────────────────────
# Resend — sends actionable audit summary when visitor audits complete (gracefully skipped if unset)
RESEND_API_KEY=re_your-resend-api-key
# For testing, onboarding@resend.dev only delivers to your Resend account email.
# For production, verify a domain at resend.com/domains and use:
# RESEND_FROM_EMAIL=SynapseCRO <hello@yourdomain.com>

# ── Optional: app URL for emails and links ─────────────────────────────────────
# Fly sets FLY_APP_NAME automatically; override with a custom domain if needed:
# NEXT_PUBLIC_APP_URL=https://synapsecro.fly.dev

# ── Fly.io cron (replaces Vercel x-vercel-cron header) ───────────────────────
# CRON_SECRET=your-random-cron-secret

# ── Reserved (not wired yet) ─────────────────────────────────────────────────
# GOOGLE_PLACES_API_KEY=your-google-places-key
